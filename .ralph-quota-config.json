{
  "_comment": "Ralph Loop Quota Configuration - copy to .ralph/quota-config.json to customize",

  "limits": {
    "contextWindow": 200000,
    "safetyThreshold": 0.85,
    "warningThreshold": 0.75,
    "reserveForExit": 5000
  },

  "estimation": {
    "parseSpec": 3000,
    "architecture": 4000,
    "implementStory": {
      "small": 8000,
      "medium": 15000,
      "large": 25000
    },
    "testStory": {
      "unit": 3000,
      "lint": 1000,
      "ui": 5000,
      "integration": 4000,
      "codeQuality": 2000
    },
    "proveRequirements": 6000,
    "archiveRun": 2000,
    "overhead": 1000
  },

  "maxIterations": {
    "enabled": false,
    "global": 100,
    "perStory": 20,
    "warningAt": 80
  },

  "behavior": {
    "pauseOnQuotaWarning": true,
    "skipNewTasksWhenLow": true,
    "saveStateOnPause": true,
    "notifyUser": true
  },

  "costEstimation": {
    "linesOfCodeFactor": 0.5,
    "complexityFactor": 1.2,
    "testCountFactor": 0.3,
    "dependencyFactor": 0.4
  }
}
